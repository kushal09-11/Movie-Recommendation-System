SUPABASE_URL=
SUPABASE_KEY=
DATABASE_URL=
ADMIN_API_TOKEN=change-me-to-a-long-random-secret

# Optional runtime settings
MOVIELENS_DATA_DIR=./data
MODEL_DIR=./models
LOCAL_RATING_STORE=./data/local_ratings.json
RECOMMENDER_TOP_K_SIMILAR=80
RECOMMENDER_MIN_SIMILARITY=0.05
RECOMMENDER_AUTO_DOWNLOAD=true

# Keep first-run training responsive on large MovieLens exports.
# Set to 0 to train on the full ratings file.
RECOMMENDER_MAX_RATINGS=1000000
